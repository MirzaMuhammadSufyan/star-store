        "title": "Worked examples",
        "paragraphs": [
          "(i) BSINOLEPRES (Knowing one's duty)",
          "(ii) MIASTRR (A City of India)",
          "(iii) MERIP (A kind of number)",
          "(iv) NONGGIPP (An indoor game)",
          "Ans.",
          "(i) RESPONSIBLE",
          "(ii) AMRITSAR",
          "(iii) PRIME",
          "(iv) PING PONG"
        ],
        "examples": []
      }
    ]
