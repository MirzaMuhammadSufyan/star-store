{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "star-store",
  "main": "src/worker.js",
  "compatibility_date": "2024-11-01",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
