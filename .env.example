# Firebase (client — Vite exposes VITE_* vars to the browser)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Canonical public site URL (no trailing slash). Used by SEO.jsx, prerender, sitemap, robots.
# Keep VITE_SITE_URL and SITE_URL identical.
VITE_SITE_URL=https://star-store.mirzamuhammadsufyanbaig.workers.dev
SITE_URL=https://star-store.mirzamuhammadsufyanbaig.workers.dev

# Optional — loads AdSense only after advertising cookie consent
# VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Comma-separated admin emails allowed to access /admin/dashboard
# Required in production builds — without this, no one can access the dashboard.
# Example: VITE_ADMIN_EMAILS=you@gmail.com,other@starstore.com
VITE_ADMIN_EMAILS=mirzamuhammadsufyanbaig@gmail.com

# Example: FIREBASE_EMAIL=you@gmail.com FIREBASE_PASSWORD=secret npm run publish:article -- the-reality-of-war
# FIREBASE_EMAIL=
# FIREBASE_PASSWORD=

# Cloudflare Worker secrets (set via: npx wrangler secret put <NAME>)
# ALIEXPRESS_APP_SECRET=
# ALIEXPRESS_TRACKING_ID=
