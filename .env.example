# Firebase (client — Vite exposes VITE_* vars to the browser)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Comma-separated admin emails allowed to access /admin/dashboard
# Must match emails in firestore.rules or use Firebase custom claims (admin: true)
VITE_ADMIN_EMAILS=admin@starstore.com

# Cloudflare Worker secrets (set via: wrangler secret put <NAME>)
# ALIEXPRESS_APP_SECRET=
# ALIEXPRESS_TRACKING_ID=
