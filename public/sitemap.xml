<?xml version="1.0" encoding="UTF-8"?>
<!--
  Static sitemap covering fixed routes only.

  NOTE — action still required before this is production-correct:
  1. Replace https://www.starstore.com below with the actual apex custom
     domain once it is purchased and cut over from the workers.dev testing
     subdomain (see checklist.txt, Phase 4).
  2. Product (/product/:id) and Journal (/blog/:id) pages are stored in
     Firestore and are created/edited at runtime, so their URLs can't be
     enumerated in a static file like this one. Once the custom domain is
     live, generate a dynamic sitemap (e.g. a small server/worker route that
     queries Firestore and emits <url> entries for every product and post),
     or submit those sections via Search Console's URL inspection tool
     individually until that automation exists.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
